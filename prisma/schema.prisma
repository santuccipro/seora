generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String                @id @default(cuid())
  name              String?
  email             String                @unique
  emailVerified     DateTime?
  image             String?
  password          String?
  tokens            Int                   @default(150)
  referralCode      String?               @unique
  referredBy        String?
  totalReferrals    Int                   @default(0)
  isAdmin           Boolean               @default(false)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  accounts              Account[]
  cvAnalyses            CVAnalysis[]
  coverLetters          CoverLetterAnalysis[]
  cvDraft               CvDraft?
  humanizerAnalyses     HumanizerAnalysis[]
  jobMatches            JobMatch[]
  jobApplications       JobApplication[]
  publicCvs             PublicCv[]
  sessions              Session[]
  tokenPurchases        TokenPurchase[]
  linkedInAnalyses      LinkedInAnalysis[]
  interviewPrepSessions InterviewPrepSession[]
  photoGenerations      PhotoGeneration[]
}

model CvDraft {
  id        String   @id @default(cuid())
  userId    String   @unique
  payload   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PublicCv {
  id        String   @id @default(cuid())
  userId    String
  slug      String   @unique
  payload   String   @db.Text
  sector    String
  firstName String
  lastName  String
  isActive  Boolean  @default(true)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model CVAnalysis {
  id             String     @id @default(cuid())
  userId         String
  fileName       String
  fileContent    String
  score          Int?
  scoreBreakdown String?
  summary        String?
  strengths      String?
  weaknesses     String?
  corrections    String?
  correctedCV    String?
  structuredCV   String?
  originalImage  String?
  status         String     @default("pending")
  tokensUsed     Int        @default(0)
  shareToken     String?    @unique
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobMatches     JobMatch[]
}

model CoverLetterAnalysis {
  id             String   @id @default(cuid())
  userId         String
  fileName       String
  fileContent    String
  score          Int?
  scoreBreakdown String?
  summary        String?
  strengths      String?
  weaknesses     String?
  corrections    String?
  correctedText  String?
  status         String   @default("pending")
  tokensUsed     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobMatch {
  id             String     @id @default(cuid())
  userId         String
  cvAnalysisId   String
  jobTitle       String
  jobDescription String
  matchScore     Int?
  adaptedCV      String?
  suggestions    String?
  keywords       String?
  status         String     @default("pending")
  tokensUsed     Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  cvAnalysis     CVAnalysis @relation(fields: [cvAnalysisId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TokenPurchase {
  id              String   @id @default(cuid())
  userId          String
  amount          Int
  price           Int
  stripeSessionId String?  @unique
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model JobApplication {
  id            String    @id @default(cuid())
  userId        String
  companyName   String
  position      String
  sector        String?
  status        String    @default("planned")
  appliedAt     DateTime?
  interviewDate DateTime?
  jobUrl        String?
  salary        String?
  location      String?
  contactName   String?
  contactEmail  String?
  notes         String?
  cvAnalysisId  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, createdAt])
}

model HumanizerAnalysis {
  id            String   @id @default(cuid())
  userId        String
  fileName      String
  fileType      String
  originalText  String
  humanizedText String?
  aiScoreBefore Int?
  aiScoreAfter  Int?
  scoreDetails  String?
  passesCount   Int      @default(0)
  wordCount     Int?
  status        String   @default("pending")
  errorMessage  String?
  tokensUsed    Int      @default(3)
  shareToken    String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model LinkedInAnalysis {
  id                   String   @id @default(cuid())
  userId               String
  targetSector         String
  targetRole           String
  targetLevel          String
  globalScore          Int
  scoreBreakdown       String   // JSON stringified
  verdict              String
  strengths            String   // JSON stringified
  weaknesses           String   // JSON stringified
  rewrittenTitle       String
  rewrittenSummary     String   @db.Text
  missingKeywords      String   // JSON stringified
  recommendedSkills    String   // JSON stringified
  quickWins            String   // JSON stringified
  recruiterInsight     String   @db.Text
  competitorComparison String   @db.Text
  tokensUsed           Int      @default(1)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model InterviewPrepSession {
  id              String   @id @default(cuid())
  userId          String
  sector          String
  position        String
  companyName     String?
  experienceLevel String?
  questions       String   @db.Text  // JSON stringified
  globalTips      String             // JSON stringified
  redFlags        String             // JSON stringified
  tokensUsed      Int      @default(1)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model PhotoGeneration {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrls   String[]
  fond        String   @default("neutre")
  tonalite    String   @default("classique")
  pose        String   @default("face")
  expression  String   @default("neutre")
  notes       String   @default("")
  tokensUsed  Int      @default(2)
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}
